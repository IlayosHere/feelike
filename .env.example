# feelike env vars — copy to `.env` and fill in. Never commit `.env`.

# -----------------------------------------------------------------------------
# Backend (FastAPI) — loaded by docker-compose and uvicorn in dev
# -----------------------------------------------------------------------------

# Postgres connection string. Local dev can use SQLite (`sqlite:///./feelike.db`).
# In prod, this is materialized in Secret Manager and injected by Cloud Run.
DATABASE_URL=sqlite:///./feelike.db

# JWT signing secret. Generate with: `python -c "import secrets; print(secrets.token_hex(32))"`
# In prod, stored in Secret Manager as `feelike_jwt_secret`.
JWT_SECRET=change-me-use-a-real-random-value

# JWT expiry in hours. Default 7 days.
TOKEN_EXPIRE_HOURS=168

# CORS — comma-separated list of allowed origins. Use exact origins in prod; localhost for dev.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Mobile (Expo) — loaded via `app/.env` and exposed as EXPO_PUBLIC_*
# -----------------------------------------------------------------------------

# Backend URL the app connects to. Use your LAN IP in dev so phones on the same
# wifi can reach it, e.g. http://192.168.1.23:8000.
EXPO_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# GCP / deploy (only needed for Phase 3+)
# -----------------------------------------------------------------------------

# Uncomment when Terraform / deploy workflows are active.
# GCP_PROJECT_ID=
# GCP_REGION=europe-west1
# GCP_WIF_PROVIDER=projects/123456/locations/global/workloadIdentityPools/github/providers/feelike
# GCP_DEPLOYER_SA=feelike-deployer@<project>.iam.gserviceaccount.com
