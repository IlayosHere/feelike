# Copy to .env.local and fill in values.
# Without a .env.local file, the app runs against the MSW mock server in dev.

# Option A: use mock API (default in dev — no file needed)
# EXPO_PUBLIC_API_URL=http://localhost:8000

# Option B: use local FastAPI backend (find your LAN IP with `ipconfig` or `ifconfig`)
# EXPO_PUBLIC_API_URL=http://<your-lan-ip>:8000

# Option C: use deployed Cloud Run backend
# EXPO_PUBLIC_API_URL=https://feelike-api-<hash>-ew.a.run.app
